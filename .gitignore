# whisper.cpp binaries and DLLs — too large for git; bundled into the installer
# at build time. Bootstrap scripts place whisper-cli and parakeet-cli target
# triple binaries into src-tauri/binaries/ for local development.
src-tauri/binaries/whisper-bin-*/
src-tauri/binaries/whisper-cli-*
src-tauri/binaries/parakeet-cli-*
src-tauri/binaries/*.exe
src-tauri/binaries/*.dll
src-tauri/parakeet-runtime/*
!src-tauri/parakeet-runtime/.gitkeep

