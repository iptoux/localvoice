{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LocalVoice",
  "version": "0.2.5",
  "identifier": "com.localvoice.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm run tauri:prepare",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "pill",
        "title": "LocalVoice",
        "width": 220,
        "height": 70,
        "minWidth": 180,
        "minHeight": 56,
        "maxWidth": 220,
        "maxHeight": 280,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": false,
        "center": false,
        "x": 60,
        "y": 60,
        "shadow": false
      },
      {
        "label": "main",
        "title": "LocalVoice",
        "width": 1100,
        "height": 720,
        "minWidth": 800,
        "minHeight": 500,
        "decorations": true,
        "visible": false,
        "center": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/256x256.png",
      "icons/icon.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "resources/nemo_worker/localvoice_nemo_worker.py",
      "resources/nemo_worker/manifest.json",
      "parakeet-runtime"
    ],
    "externalBin": [
      "binaries/whisper-cli",
      "binaries/parakeet-cli",
      "binaries/parakeet-stream-worker"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEMxNzcyMjM0OEQyOTdBMzQKUldRMGVpbU5OQ0ozd1pFbzQwaURuaFRjN3lTOGpzeWl6Z3FkNXNwYkpBcGo5eDkyWmN6SmlzblYK",
      "endpoints": [
        "https://github.com/iptoux/localvoice/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
