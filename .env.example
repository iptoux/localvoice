# LocalVoice Environment Variables

# Whisper.cpp Configuration
# Path to whisper.cpp binary (leave empty for auto-discovery)
# WHISPER_CLI_PATH=

# Model paths (leave empty to use default location: {app_data}/models/)
# WHISPER_MODEL_PATH_DE=
# WHISPER_MODEL_PATH_EN=

# Logging
# Log level: trace, debug, info, warn, error
# RUST_LOG=info

# Development
# Set to 'true' to enable verbose logging
# DEBUG=false
